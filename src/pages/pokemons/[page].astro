---
import 'src/styles/global.css';
import type { GetStaticPaths } from "astro";
import PokemonCard from '../../components/pokemons/PokemonCard.astro';
import type { PokemonListResponse } from '../../interfaces/pokemon-list.response';
import MainLayout from '../../Layouts/MainLayout.astro';

export const getStaticPaths = (async({paginate}) => {
	const resp = await fetch('https://pokeapi.co/api/v2/pokemon?limit=151');
	const { results } = (await resp.json()) as { results: { name: string; url: string }[] };

	return paginate(results, {pageSize: 10});
}) satisfies GetStaticPaths;
const {page} = Astro.props;
---
<MainLayout title="Pokemon | Home">
		<h1 class="text-3xl">Listado de Pokémons</h1>
		<hr/><br>
		<section aria-label="Listado de Pokemons"
		class="grid grid-cols-1 sm:grid-cols-3 md:grid-cols-3 gap-4 mt-5">

		{page.data.map(({url, name}) => 
		<PokemonCard
		url= {url}
		name= {name}/>
		) } 

		</section>
</MainLayout>
