---
import type { boolean } from 'astro:schema';

interface Props{//Creacion de Variables
    url: string;
    name: string;
    isBig?: boolean;
}
const{url, name, isBig = false} = Astro.props;//uso de variables
const id = url.split('/').at(-2);
const imageUrl = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/home/shiny/${id}.png`;
---
 <a href=`/pokemons/${name}`}
 class:list={[
    `rounded border flex flex-col justify-center items-center p-2`,
    {
        border: !isBig,
    },
 ]}
 >
    <img 
        transition:name={`${name}-image`}
        class:list={[
        {
            'w-26 h-26': isBig,
            'w-22 h-16': !isBig,
        },
        ]}
        src={imageUrl} alt={name} />
        
    <span 
        class:list={[
            'capitalize',
            {
                'text-4xl text-blue-500': isBig,
            },
        ]}>#{id} {name}</span>
 </a>